# arcoventure-mcp-server environment configuration
# Copy to .env and fill in real values: `cp .env.example .env`
# Never commit .env. All variables must be set in Railway before first deploy.

# --- GitHub (Lexicon data source) -------------------------------------------
# Personal access token for GitHub API reads (avoids the 60 req/hour
# unauthenticated limit). Read-only access to the data repo is sufficient.
GITHUB_TOKEN=

# Owner and repo for the Lexicon term Markdown files.
GITHUB_REPO_OWNER=arcoventure
GITHUB_REPO_NAME=awesome-autonomous-business

# Directory within the repo that holds one Markdown file per term.
GITHUB_TERMS_PATH=terms

# --- Supabase (mcp_usage_log analytics only) --------------------------------
# No term definitions are stored in Supabase — usage logging only.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Admin ------------------------------------------------------------------
# Bearer token required by POST /admin/refresh. Generate a long random value.
MCP_REFRESH_TOKEN=

# --- Server -----------------------------------------------------------------
# Railway sets PORT automatically in production; set it locally for `npm run dev`.
PORT=3000

# Public URL advertised in the MCP server card (/.well-known/mcp/server-card.json).
# Defaults to https://mcp.arcoventure.studio/mcp when unset.
MCP_ENDPOINT_URL=
